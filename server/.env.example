# M-Pesa Configuration
MPESA_CONSUMER_KEY=your_consumer_key_here
MPESA_CONSUMER_SECRET=your_consumer_secret_here
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_passkey_here

# For Sandbox (testing)
# Use ngrok or similar to get a public URL for callbacks
# ngrok http 3001
MPESA_CALLBACK_URL=https://your-ngrok-url.ngrok-free.app/api/mpesa/callback
MPESA_B2C_CALLBACK_URL=https://your-ngrok-url.ngrok-free.app/api/mpesa/b2c-callback

# For Production
# Replace with your production domain
# MPESA_CALLBACK_URL=https://your-domain.com/api/mpesa/callback
# MPESA_B2C_CALLBACK_URL=https://your-domain.com/api/mpesa/b2c-callback

# B2C Security Credentials
MPESA_INITIATOR_NAME=testapi
MPESA_INITIATOR_PASSWORD=your_security_credential_here

# JWT Secret
JWT_SECRET=your_jwt_secret_here
